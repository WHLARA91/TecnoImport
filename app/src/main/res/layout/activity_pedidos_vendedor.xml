<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    tools:context=".vendedor.PedidosVendedorActivity">

    <!-- TITULO -->
    <TextView
        android:id="@+id/txtTituloPedidos"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pedidos"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="24dp"
        android:layout_marginStart="20dp"/>

    <!-- SUBTITULO -->
    <TextView
        android:id="@+id/txtSubPedidos"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gestiona los pedidos de tus clientes"
        android:textColor="@color/text_gray"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/txtTituloPedidos"
        app:layout_constraintStart_toStartOf="@id/txtTituloPedidos"
        android:layout_marginTop="4dp"/>

    <!-- FILTROS -->
    <LinearLayout
        android:id="@+id/layoutFiltrosPedidos"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3"
        app:layout_constraintTop_toBottomOf="@id/txtSubPedidos"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPendientes"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_weight="1"
            android:text="Pendientes"
            android:textAllCaps="false"
            android:backgroundTint="@color/primary_blue"
            app:cornerRadius="12dp"
            android:layout_marginEnd="6dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEnviados"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_weight="1"
            android:text="Enviados"
            android:textAllCaps="false"
            android:backgroundTint="@color/card_dark"
            app:strokeColor="@color/primary_blue"
            app:strokeWidth="1dp"
            app:cornerRadius="12dp"
            android:layout_marginEnd="6dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFinalizados"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_weight="1"
            android:text="Finalizados"
            android:textAllCaps="false"
            android:backgroundTint="@color/card_dark"
            app:strokeColor="@color/primary_blue"
            app:strokeWidth="1dp"
            app:cornerRadius="12dp"/>
    </LinearLayout>

    <!-- LISTA PEDIDOS -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerPedidosVendedor"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="12dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/layoutFiltrosPedidos"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>