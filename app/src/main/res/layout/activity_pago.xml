<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    tools:context=".payment.PagoActivity">

    <!-- TITULO -->
    <TextView
        android:id="@+id/txtTituloPago"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Finalizar compra"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="24dp"
        android:layout_marginStart="20dp"/>

    <!-- SUBTITULO -->
    <TextView
        android:id="@+id/txtSubPago"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Completa los datos para realizar el pago"
        android:textColor="@color/text_gray"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/txtTituloPago"
        app:layout_constraintStart_toStartOf="@id/txtTituloPago"
        android:layout_marginTop="4dp"/>

    <!-- RESUMEN DE COMPRA -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardResumenPago"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/card_dark"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/txtSubPago"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="16dp">

    </com.google.android.material.card.MaterialCardView>

    <!-- METODO DE PAGO -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardMetodoPago"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/card_dark"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/cardResumenPago"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="16dp">

    </com.google.android.material.card.MaterialCardView>

    <!-- BOTON PAGAR -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirmarPago"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="Confirmar pago"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:textSize="16sp"
        android:backgroundTint="@color/primary_blue"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="20dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        tools:layout_editor_absoluteX="16dp"
        tools:layout_editor_absoluteY="149dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Método de pago"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- TARJETA -->
        <com.google.android.material.radio.MaterialRadioButton
            android:id="@+id/rbTarjeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Tarjeta de crédito / débito"
            android:textColor="@color/text_gray"
            android:textColorHint="@color/text_gray" />

        <!-- PSE / TRANSFERENCIA -->
        <com.google.android.material.radio.MaterialRadioButton
            android:id="@+id/rbPse"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PSE / Transferencia"
            android:textColor="@color/text_gray" />

        <!-- EFECTIVO -->
        <com.google.android.material.radio.MaterialRadioButton
            android:id="@+id/rbEfectivo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pago contra entrega"
            android:textColor="@color/text_gray" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        tools:layout_editor_absoluteX="16dp"
        tools:layout_editor_absoluteY="309dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Resumen del pedido"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtResumen"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="3 productos seleccionados"
            android:textColor="@color/text_gray" />

        <TextView
            android:id="@+id/txtTotalPago"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Total: $0"
            android:textColor="@color/primary_blue"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>