<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    tools:context=".vendedor.DashboardVendedorActivity">

    <!-- LOGO -->

    <ImageView
        android:id="@+id/imgLogoVendedor"
        android:layout_width="170dp"
        android:layout_height="170dp"
        android:src="@drawable/logo_tecnoimport"
        android:contentDescription="@string/app_name"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- TITULO -->

    <TextView
        android:id="@+id/txtVendedor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Panel Vendedor"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/imgLogoVendedor"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- SUBTITULO -->

    <TextView
        android:id="@+id/txtSubVendedor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gestiona tus ventas y pedidos"
        android:textColor="@color/text_gray"
        android:textSize="14sp"
        android:layout_marginTop="5dp"
        app:layout_constraintTop_toBottomOf="@id/txtVendedor"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- CARD RESUMEN -->

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardResumenVendedor"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="16dp"
        app:cardBackgroundColor="@color/card_dark"
        app:cardCornerRadius="18dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/txtSubVendedor"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resumen de hoy"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtVentasHoy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ventas: 0"
                android:textColor="@color/primary_blue"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="10dp"/>

            <TextView
                android:id="@+id/txtComision"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Comisión: $0"
                android:textColor="@color/text_gray"
                android:layout_marginTop="5dp"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- BOTON AGREGAR PRODUCTO -->

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAgregarProducto"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:text="Agregar Producto"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:backgroundTint="@color/primary_blue"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:cornerRadius="14dp"
        app:layout_constraintTop_toBottomOf="@id/cardResumenVendedor"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- BOTONES PEDIDOS E HISTORIAL -->

    <LinearLayout
        android:id="@+id/layoutAcciones"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_marginTop="14dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnAgregarProducto"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPedidos"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="Pedidos"
            android:textAllCaps="false"
            android:backgroundTint="@color/primary_blue"
            app:cornerRadius="12dp"
            android:layout_marginEnd="6dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHistorial"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="Historial"
            android:textAllCaps="false"
            android:backgroundTint="@color/card_dark"
            app:strokeColor="@color/primary_blue"
            app:strokeWidth="1dp"
            app:cornerRadius="12dp"/>

    </LinearLayout>

    <!-- RECYCLERVIEW -->

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerVendedor"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="12dp"
        android:clipToPadding="false"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/layoutAcciones"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@id/layoutAcciones"
        app:layout_constraintEnd_toEndOf="@id/layoutAcciones"/>

</androidx.constraintlayout.widget.ConstraintLayout>