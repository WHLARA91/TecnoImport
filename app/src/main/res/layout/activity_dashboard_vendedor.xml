<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    tools:context=".vendedor.DashboardVendedorActivity">

    <!-- HEADER -->
    <ImageView
        android:id="@+id/imgLogoVendedor"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/Logo_tecnoimport"
        android:contentDescription="@string/app_name"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="30dp"/>

    <TextView
        android:id="@+id/txtVendedor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Panel Vendedor"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/imgLogoVendedor"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="10dp"/>

    <TextView
        android:id="@+id/txtSubVendedor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gestiona tus ventas y pedidos"
        android:textColor="@color/text_gray"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/txtVendedor"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4dp"/>

    <!-- CARD RESUMEN -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardResumenVendedor"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/card_dark"
        app:cardCornerRadius="18dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/txtSubVendedor"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resumen de hoy"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/txtVentasHoy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ventas: 0"
                android:textColor="@color/primary_blue"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginTop="10dp"/>

            <TextView
                android:id="@+id/txtComision"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Comisión: $0"
                android:textColor="@color/text_gray"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- BOTONES ACCION RAPIDA -->
    <LinearLayout
        android:id="@+id/layoutAcciones"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        app:layout_constraintTop_toBottomOf="@id/cardResumenVendedor"
        app:layout_constraintStart_toStartOf="@id/cardResumenVendedor"
        app:layout_constraintEnd_toEndOf="@id/cardResumenVendedor">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPedidos"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="Pedidos"
            android:textAllCaps="false"
            android:backgroundTint="@color/primary_blue"
            app:cornerRadius="12dp"
            android:layout_marginEnd="6dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHistorial"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="Historial"
            android:textAllCaps="false"
            android:backgroundTint="@color/card_dark"
            app:strokeColor="@color/primary_blue"
            app:strokeWidth="1dp"
            app:cornerRadius="12dp"/>
    </LinearLayout>

    <!-- LISTA DE ACTIVIDAD -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerVendedor"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="12dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/layoutAcciones"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@id/cardResumenVendedor"
        app:layout_constraintEnd_toEndOf="@id/cardResumenVendedor"
        android:layout_marginTop="10dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>