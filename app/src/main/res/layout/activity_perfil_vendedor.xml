<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    tools:context=".vendedor.PerfilVendedorActivity">

    <!-- FOTO PERFIL -->
    <ImageView
        android:id="@+id/imgPerfil"
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:src="@drawable/vendedor.png"
        android:background="@drawable/bg_biometric"
        android:padding="20dp"
        app:tint="@color/primary_blue"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp"/>

    <!-- NOMBRE -->
    <TextView
        android:id="@+id/txtNombreVendedor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nombre Vendedor"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/imgPerfil"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"/>

    <!-- EMAIL -->
    <TextView
        android:id="@+id/txtEmailVendedor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="vendedor@correo.com"
        android:textColor="@color/text_gray"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/txtNombreVendedor"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4dp"/>

    <!-- CARD ESTADISTICAS -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardStats"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/card_dark"
        app:cardCornerRadius="18dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/txtEmailVendedor"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mis estadísticas"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/txtVentasPerfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ventas realizadas: 0"
                android:textColor="@color/primary_blue"
                android:layout_marginTop="10dp"/>

            <TextView
                android:id="@+id/txtComisionPerfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Comisión acumulada: $0"
                android:textColor="@color/text_gray"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/txtPedidosPerfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pedidos gestionados: 0"
                android:textColor="@color/text_gray"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- OPCIONES -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardOpciones"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/card_dark"
        app:cardCornerRadius="18dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/cardStats"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Opciones"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/btnEditarPerfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Editar perfil"
                android:textColor="@color/primary_blue"
                android:layout_marginTop="12dp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/btnConfiguracion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Configuración"
                android:textColor="@color/text_gray"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/btnCerrarSesion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cerrar sesión"
                android:textColor="@color/primary_blue"
                android:layout_marginTop="8dp"
                android:textStyle="bold"/>
        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>