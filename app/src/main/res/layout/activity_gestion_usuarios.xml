<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    tools:context=".admin.GestionUsuariosActivity">

    <!-- TITULO -->

    <!-- SUBTITULO -->

    <!-- BUSCADOR -->

    <TextView
        android:id="@+id/txtTituloUsuarios"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="96dp"
        android:layout_marginTop="116dp"
        android:text="Gestión de usuarios"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txtSubUsuarios"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Administra los usuarios del sistema"
        android:textColor="@color/text_gray"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="@id/txtTituloUsuarios"
        app:layout_constraintTop_toBottomOf="@id/txtTituloUsuarios" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layoutBuscarUsuario"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Buscar usuario"
        app:boxBackgroundColor="@color/card_dark"
        app:boxCornerRadiusTopStart="14dp"
        app:boxCornerRadiusTopEnd="14dp"
        app:boxCornerRadiusBottomStart="14dp"
        app:boxCornerRadiusBottomEnd="14dp"
        app:boxStrokeColor="@color/primary_blue"
        app:hintTextColor="@color/text_gray"
        app:layout_constraintTop_toBottomOf="@id/txtSubUsuarios"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="16dp">

    </com.google.android.material.textfield.TextInputLayout>

    <!-- BOTON AGREGAR USUARIO -->

    <!-- LISTA USUARIOS -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAgregarUsuario"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginTop="80dp"
        android:backgroundTint="@color/primary_blue"
        android:text="Agregar usuario"
        android:textAllCaps="false"
        android:textStyle="bold"
        app:cornerRadius="14dp"
        app:layout_constraintEnd_toEndOf="@id/layoutBuscarUsuario"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@id/layoutBuscarUsuario"
        app:layout_constraintTop_toBottomOf="@id/layoutBuscarUsuario" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerUsuarios"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="12dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/btnAgregarUsuario"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@id/layoutBuscarUsuario"
        app:layout_constraintEnd_toEndOf="@id/layoutBuscarUsuario"
        android:layout_marginTop="10dp"/>

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/etBuscarUsuario"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="text"
        android:textColor="@color/white"
        tools:layout_editor_absoluteX="64dp"
        tools:layout_editor_absoluteY="251dp" />

</androidx.constraintlayout.widget.ConstraintLayout>